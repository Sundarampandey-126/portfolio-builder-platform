<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Portfolio Builder Platform</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f4f6f9;
padding:20px;
}

h1{
text-align:center;
margin-bottom:20px;
color:#2c3e50;
}

.container{
display:flex;
gap:20px;
flex-wrap:wrap;
}

.form-section,
.preview-section{
flex:1;
min-width:350px;
background:white;
padding:20px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,0.1);
}

input,textarea{
width:100%;
padding:10px;
margin-top:5px;
margin-bottom:15px;
border:1px solid #ccc;
border-radius:5px;
}

button{
width:100%;
padding:12px;
background:#3498db;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
font-size:16px;
}

button:hover{
background:#2980b9;
}

.portfolio-card{
text-align:center;
}

.profile{
width:120px;
height:120px;
border-radius:50%;
background:#ddd;
margin:auto;
margin-bottom:15px;
display:flex;
align-items:center;
justify-content:center;
font-size:40px;
}

.section{
margin-top:15px;
text-align:left;
}

.section h3{
color:#3498db;
margin-bottom:5px;
border-bottom:2px solid #3498db;
padding-bottom:5px;
}
</style>
</head>
<body>

<h1>Portfolio Builder Platform</h1>

<div class="container">

<div class="form-section">

<label>Name</label>
<input type="text" id="name">

<label>About</label>
<textarea id="about"></textarea>

<label>Skills</label>
<input type="text" id="skills" placeholder="HTML, CSS, JavaScript">

<label>Projects</label>
<textarea id="projects"></textarea>

<label>Contact</label>
<input type="text" id="contact">

<button onclick="generatePortfolio()">
Generate Portfolio
</button>

</div>

<div class="preview-section">

<div class="portfolio-card">

<div class="profile">👨</div>

<h2 id="pname">Your Name</h2>

<div class="section">
<h3>About</h3>
<p id="pabout">About section will appear here.</p>
</div>

<div class="section">
<h3>Skills</h3>
<p id="pskills">Skills will appear here.</p>
</div>

<div class="section">
<h3>Projects</h3>
<p id="pprojects">Projects will appear here.</p>
</div>

<div class="section">
<h3>Contact</h3>
<p id="pcontact">Contact details here.</p>
</div>

</div>

</div>

</div>

<script>
function generatePortfolio(){

document.getElementById("pname").innerHTML =
document.getElementById("name").value;

document.getElementById("pabout").innerHTML =
document.getElementById("about").value;

document.getElementById("pskills").innerHTML =
document.getElementById("skills").value;

document.getElementById("pprojects").innerHTML =
document.getElementById("projects").value;

document.getElementById("pcontact").innerHTML =
document.getElementById("contact").value;
}
</script>

</body>
</html>
